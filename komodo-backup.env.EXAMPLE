# ==============================================================================
# KOMODO & RESTIC BACKUP PIPELINE - ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# Copy this file to /etc/komodo-backup.env on your host machine and populate
# the fields below. Do NOT commit the populated production file to Git!
# ==============================================================================

# --- KOMODO API CREDENTIALS ---
# Your unique Komodo API Access Key and Secret Token used to handle 
# stack container degradation (Stop/Start sequences).
KOMODO_KEY=""
KOMODO_SECRET=""

# --- RESTIC CREDENTIALS ---
# The target repository path (e.g., rest:https://your-storage-box-url) 
# and the secure encryption password used to lock your offsite repository.
RESTIC_REPOSITORY=""
RESTIC_PASSWORD=""

# --- NOTIFICATION CREDENTIALS ---
# The destination email address where systemd failure alerts 
# will be routed if a backup run crashes.
NOTIFICATION_EMAIL=""

# --- OPTIONAL EXTENSIONS ---
# Add any additional provider keys here if you change backends down the road.
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
